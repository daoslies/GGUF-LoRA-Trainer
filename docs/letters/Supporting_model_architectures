def test_registry_routes_qwen3_correctly():
    name_map = get_name_map("qwen3-4b-q8_0.gguf")
    assert name_map.ARCHITECTURE_ID == 'qwen3'

def test_unsupported_architecture_raises():
    with pytest.raises(NotImplementedError):
        get_name_map("some_unknown_arch.gguf")

def test_no_unmapped_tensors_in_real_file():
    from gguf import GGUFReader
    reader = GGUFReader("qwen3-4b-q8_0.gguf")
    name_map = get_name_map("qwen3-4b-q8_0.gguf")
    unmapped = [
        t.name for t in reader.tensors
        if name_map.gguf_to_hf(t.name) is None
    ]
    assert unmapped == [], f"Unmapped tensors: {unmapped}"

The principle behind this change
We investigated three real models before writing any production code. Each one revealed something the design needed to handle. That's the right order of operations — look at real data, then design, then build.
The registry pattern costs almost nothing in complexity — one extra directory, one extra file — and it pays back immediately the moment a second architecture is added. Build it right once. The Qwen3-4B is a clean first case. Do it properly for that one and every architecture after it is free.
